# Robust AI Document Extractor - Docker Environment
# Use a slim Python image for efficiency
FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Install system dependencies for core libraries (OpenCV, PDF processing)
RUN apt-get update && apt-get install -y \
    libgl1-mesa-glx \
    libglib2.0-0 \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the rest of the application
COPY . .

# Create necessary directories
RUN mkdir -p data/raw data/processed .refinery/profiles

# Environment variables
# Note: To connect to Ollama running on host, use http://host.docker.internal:11434
ENV OLLAMA_BASE_URL="http://host.docker.internal:11434/v1"

# Command to run the pipeline
CMD ["python", "main.py"]
